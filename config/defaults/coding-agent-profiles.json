{
  "version": 2,
  "defaults": {
    "planning": "codex_planning",
    "build": "codex_build"
  },
  "profiles": [
    {
      "name": "codex_planning",
      "provider": "codex-cli",
      "package": "@openai/codex",
      "command": "codex",
      "purpose": "planning",
      "sandbox": "read-only",
      "args": ["exec", "--json", "--sandbox", "read-only"]
    },
    {
      "name": "codex_build",
      "provider": "codex-cli",
      "package": "@openai/codex",
      "command": "codex",
      "purpose": "build",
      "sandbox": "workspace-write",
      "args": ["exec", "--json", "--sandbox", "workspace-write"]
    },
    {
      "name": "claude_planning",
      "provider": "claude-code-cli",
      "package": "@anthropic-ai/claude-code",
      "command": "claude",
      "purpose": "planning",
      "sandbox": "read-only",
      "args": ["--print", "--output-format", "json", "--permission-mode", "plan", "--no-session-persistence"]
    },
    {
      "name": "claude_build",
      "provider": "claude-code-cli",
      "package": "@anthropic-ai/claude-code",
      "command": "claude",
      "purpose": "build",
      "sandbox": "workspace-write",
      "args": ["--print", "--output-format", "json", "--permission-mode", "acceptEdits", "--no-session-persistence"]
    }
  ]
}
