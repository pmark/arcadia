{
  "name": "arcadia-core",
  "version": "0.1.0",
  "description": "Local-first project operating system CLI for creative and software work.",
  "type": "module",
  "private": true,
  "bin": {
    "arcadia": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm --filter arcadia-discord-bot build",
    "test": "vitest run",
    "arcadia": "tsx src/cli.ts",
    "dashboard": "pnpm --filter arcadia-dashboard dev",
    "dashboard:build": "pnpm --filter arcadia-dashboard build",
    "test:e2e": "playwright test",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.7.0"
}
