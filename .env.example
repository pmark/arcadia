# Workspace the CLI operates on (default: nearest workspace marker, then
# user config default workspace)
ARCADIA_WORKSPACE=/absolute/path/to/arcadia-workspace

# Override path to the user config file (default `~/.config/arcadia/config.json`,
# or `%APPDATA%\Arcadia\config.json` on Windows)
ARCADIA_CONFIG_PATH=

# Base URL of the running `arcadia intelligence serve` API, used by
# companion apps such as the dashboard (default `http://127.0.0.1:4710`)
ARCADIA_INTELLIGENCE_BASE_URL=

# Bounded Intelligence worker concurrency. Cloud and Codex defaults favor
# parallel throughput; local defaults are conservative for RAM/VRAM safety.
# ARCADIA_INTELLIGENCE_LOCAL_CONCURRENCY=1
# ARCADIA_INTELLIGENCE_CLOUD_TEXT_CONCURRENCY=4
# ARCADIA_INTELLIGENCE_CLOUD_IMAGE_CONCURRENCY=2
# ARCADIA_INTELLIGENCE_CODEX_CONCURRENCY=3
# ARCADIA_INTELLIGENCE_COMFYUI_CONCURRENCY=1
# ARCADIA_INTELLIGENCE_LOCAL_SPEECH_CONCURRENCY=1
# ARCADIA_INTELLIGENCE_CLOUD_SPEECH_CONCURRENCY=4
# ARCADIA_INTELLIGENCE_SCAN_LIMIT=100

# LiteLLM proxy URL (default `http://127.0.0.1:4000`)
ARCADIA_LITELLM_BASE_URL=

# local text route/alias (default `arcadia-default`)
ARCADIA_LITELLM_LOCAL_TEXT_ROUTE=

# cloud text route/alias (unset = disabled)
ARCADIA_LITELLM_CLOUD_TEXT_ROUTE=

# cloud image route/alias (unset = disabled)
ARCADIA_LITELLM_CLOUD_IMAGE_ROUTE=

# optional bearer token forwarded to the proxy
ARCADIA_LITELLM_API_KEY=

# --- Text-to-speech (audio.speech.generate) ---
# Speech is LiteLLM-routed like text/image (ARCADIA_LITELLM_BASE_URL /
# ARCADIA_LITELLM_API_KEY above); these are just the model aliases.

# local speech route/model alias, e.g. a LiteLLM alias mapped to a local
# Kokoro server (unset = local speech disabled)
ARCADIA_SPEECH_LOCAL_ROUTE=

# cloud speech route/alias, served via the LiteLLM proxy (unset = disabled)
ARCADIA_SPEECH_CLOUD_ROUTE=

# optional JSON overriding the semantic voiceId -> provider voice map, e.g.
# '{"arcadia.narrator":"af_heart"}' (merged over the built-in defaults)
ARCADIA_SPEECH_VOICE_MAP=

# optional speech request timeout in ms (default 60000)
ARCADIA_SPEECH_TIMEOUT_MS=

# enables the local Codex CLI image route when set, for example `codex-cli`
ARCADIA_CODEX_IMAGE_ROUTE=codex-cli

# Codex command (default `codex`)
# ARCADIA_CODEX_CLI_COMMAND=

# JSON array of args (default runs `codex exec` in the isolated job workspace)
# ARCADIA_CODEX_CLI_ARGS=

# Codex image job timeout (default `120000`)
# ARCADIA_CODEX_CLI_TIMEOUT_MS=

# Codex home directory used to read local goal/state sqlite files for
# `arcadia codex` observation (default `$CODEX_HOME`, then `~/.codex`)
# ARCADIA_CODEX_HOME=
